{
  "name": "root",
  "version": "0.0.0",
  "description": "api of static site",
  "author": {
    "name": "guanghechen",
    "url": "https://github.com/guanghechen/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guanghechen/asset.git"
  },
  "homepage": "https://github.com/guanghechen/asset/#readme",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    ":publish": "pnpm clean && pnpm build:production && pnpm test:coverage && pnpm -r publish --no-git-checks",
    ":upgrade": "pnpm update -i && pnpm clean && pnpm format && pnpm build && pnpm test",
    "build": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=true pnpm -r run build",
    "build:production": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=false pnpm -r run build",
    "clean": "pnpm -r run clean && pnpm install",
    "format": "pnpm format:lintfix && pnpm format:prettier",
    "format:prettier": "prettier . --write",
    "format:lintfix": "eslint . --fix",
    "prepublishOnly": "pinst --disable",
    "postinstall": "is-ci || husky",
    "postpublish": "pinst --enable",
    "rebuild": "pnpm clean && pnpm build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:update": "vitest -u --passWithNoTests",
    "version": "pnpm install && node script/sync-doc-link.mjs && git stage -u pnpm-lock.yaml packages/**/package.json packages/**/*.md",
    ":publish:all": "pnpm -r exec npm version patch --no-git-tag-version && pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "10.0.1",
    "@guanghechen/reporter": "^3.3.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/js-yaml": "4.0.9",
    "@types/micromatch": "4.0.10",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "@yozora/parser": "^2.3.16",
    "cross-env": "10.1.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.17.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "lint-staged": "17.0.8",
    "pinst": "3.0.0",
    "prettier": "3.9.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "rollup-plugin-dts": "6.4.1",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,eslintrc}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.2"
}

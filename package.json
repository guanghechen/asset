{
  "name": "root",
  "version": "0.0.0",
  "description": "api of static site",
  "author": {
    "name": "guanghechen",
    "url": "https://github.com/guanghechen/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guanghechen/asset.git"
  },
  "homepage": "https://github.com/guanghechen/asset/#readme",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    ":publish": "pnpm clean && pnpm build:production && pnpm test:coverage && pnpm -r publish --no-git-checks",
    ":upgrade": "pnpm update -i && pnpm clean && pnpm format && pnpm build && pnpm test",
    "build": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=true pnpm -r run build",
    "build:production": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=false pnpm -r run build",
    "clean": "pnpm -r run clean && pnpm install",
    "format": "run-s format:lintfix format:prettier",
    "format:prettier": "prettier . --write",
    "format:lintfix": "eslint . --fix",
    "prepublishOnly": "pinst --disable",
    "postinstall": "run-s postinstall:dev",
    "postinstall:dev": "is-ci || husky install",
    "postpublish": "pinst --enable",
    "rebuild": "run-s clean build",
    "run:ts": "node --loader ts-node/esm",
    "test": "pnpm -r run --if-present test",
    "test:coverage": "pnpm -r run --if-present test:coverage",
    "test:update": "pnpm -r run --if-present test:update",
    "version": "pnpm install && ghc-doc-link-rewrite && git stage -u pnpm-lock.yaml packages/**/package.json packages/**/*.md",
    ":publish:all": "pnpm -r exec npm version patch --no-git-tag-version && pnpm -r publish --no-git-checks"
  },
  "devDependencies": {
    "@guanghechen/chalk": "^1.0.4",
    "@guanghechen/eslint-config": "^7.0.20",
    "@guanghechen/invariant": "^7.0.2",
    "@guanghechen/jest-config": "^6.0.4",
    "@guanghechen/monorepo": "^1.0.5",
    "@guanghechen/reporter": "^3.3.0",
    "@guanghechen/rollup-config": "^6.0.11",
    "@guanghechen/script-doc-link": "^6.0.9",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/micromatch": "4.0.10",
    "@types/mime": "4.0.0",
    "@types/node": "25.3.2",
    "@types/uuid": "11.0.0",
    "@yozora/parser": "^2.3.14",
    "cross-env": "10.1.0",
    "eslint": "9.39.3",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jest": "30.2.0",
    "lint-staged": "16.2.7",
    "npm-run-all": "4.1.5",
    "pinst": "3.0.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.2"
}
